// ============================================================
// Stationery Management System - Declarative Jenkins Pipeline
// ============================================================
// Prerequisites:
//   - Jenkins with Pipeline plugin
//   - Maven 3.9+ configured as 'Maven-3.9' in Global Tool Config
//   - JDK 17 configured as 'JDK-17' in Global Tool Config
//   - Node.js 18 configured as 'NodeJS-18' via NodeJS plugin
//   - Docker & Docker Compose installed on Jenkins agent
//   - Docker registry credentials stored as 'docker-registry-creds'
// ============================================================

pipeline {
    agent any

    tools {
        maven 'Maven-3.9'
        jdk 'JDK-17'
        nodejs 'NodeJS-18'
    }

    environment {
        DOCKER_REGISTRY  = credentials('docker-registry-url')
        DOCKER_CREDS     = credentials('docker-registry-creds')
        IMAGE_TAG        = "${env.BUILD_NUMBER}"
        COMPOSE_PROJECT  = 'sms'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        // ──────────────────────────────────────────────────
        // Stage 1: Checkout Source Code
        // ──────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                echo '🔄 Checking out source code...'
                checkout scm
            }
        }

        // ──────────────────────────────────────────────────
        // Stage 2: Build All Backend Services (Parallel)
        // ──────────────────────────────────────────────────
        stage('Build Backend Services') {
            parallel {
                stage('Config Server') {
                    steps {
                        dir('backend/config-server') {
                            echo '🔨 Building Config Server...'
                            bat 'mvn clean package -DskipTests -B'
                        }
                    }
                }
                stage('Eureka Server') {
                    steps {
                        dir('backend/eureka-server') {
                            echo '🔨 Building Eureka Server...'
                            bat 'mvn clean package -DskipTests -B'
                        }
                    }
                }
                stage('API Gateway') {
                    steps {
                        dir('backend/api-gateway') {
                            echo '🔨 Building API Gateway...'
                            bat 'mvn clean package -DskipTests -B'
                        }
                    }
                }
                stage('Auth Service') {
                    steps {
                        dir('backend/auth-service') {
                            echo '🔨 Building Auth Service...'
                            bat 'mvn clean package -DskipTests -B'
                        }
                    }
                }
                stage('Inventory Service') {
                    steps {
                        dir('backend/inventory-service') {
                            echo '🔨 Building Inventory Service...'
                            bat 'mvn clean package -DskipTests -B'
                        }
                    }
                }
                stage('Request Service') {
                    steps {
                        dir('backend/request-service') {
                            echo '🔨 Building Request Service...'
                            bat 'mvn clean package -DskipTests -B'
                        }
                    }
                }
            }
        }

        // ──────────────────────────────────────────────────
        // Stage 3: Run Unit & Integration Tests (Parallel)
        // ──────────────────────────────────────────────────
        stage('Run Tests') {
            parallel {
                stage('Auth Service Tests') {
                    steps {
                        dir('backend/auth-service') {
                            echo '🧪 Running Auth Service tests...'
                            bat 'mvn test -B'
                        }
                    }
                    post {
                        always {
                            junit allowEmptyResults: true,
                                  testResults: 'backend/auth-service/target/surefire-reports/*.xml'
                        }
                    }
                }
                stage('Inventory Service Tests') {
                    steps {
                        dir('backend/inventory-service') {
                            echo '🧪 Running Inventory Service tests...'
                            bat 'mvn test -B'
                        }
                    }
                    post {
                        always {
                            junit allowEmptyResults: true,
                                  testResults: 'backend/inventory-service/target/surefire-reports/*.xml'
                        }
                    }
                }
                stage('Request Service Tests') {
                    steps {
                        dir('backend/request-service') {
                            echo '🧪 Running Request Service tests...'
                            bat 'mvn test -B'
                        }
                    }
                    post {
                        always {
                            junit allowEmptyResults: true,
                                  testResults: 'backend/request-service/target/surefire-reports/*.xml'
                        }
                    }
                }
            }
        }

        // ──────────────────────────────────────────────────
        // Stage 4: Build React Frontend
        // ──────────────────────────────────────────────────
        stage('Build Frontend') {
            steps {
                dir('frontend') {
                    echo '🌐 Installing frontend dependencies...'
                    bat 'npm ci'

                    echo '🌐 Building frontend production bundle...'
                    bat 'npm run build'
                }
            }
        }

        // ──────────────────────────────────────────────────
        // Stage 5: Run Frontend Tests
        // ──────────────────────────────────────────────────
        stage('Frontend Tests') {
            steps {
                dir('frontend') {
                    echo '🧪 Running frontend tests...'
                    bat 'npm test -- --watchAll=false --ci'
                }
            }
        }

        // ──────────────────────────────────────────────────
        // Stage 6: Build Docker Images (Parallel)
        // ──────────────────────────────────────────────────
        stage('Docker Build') {
            parallel {
                stage('Docker: Config Server') {
                    steps {
                        echo '🐳 Building Config Server image...'
                        bat "docker build -t %DOCKER_REGISTRY%/sms-config-server:%IMAGE_TAG% ./backend/config-server"
                        bat "docker tag %DOCKER_REGISTRY%/sms-config-server:%IMAGE_TAG% %DOCKER_REGISTRY%/sms-config-server:latest"
                    }
                }
                stage('Docker: Eureka Server') {
                    steps {
                        echo '🐳 Building Eureka Server image...'
                        bat "docker build -t %DOCKER_REGISTRY%/sms-eureka-server:%IMAGE_TAG% ./backend/eureka-server"
                        bat "docker tag %DOCKER_REGISTRY%/sms-eureka-server:%IMAGE_TAG% %DOCKER_REGISTRY%/sms-eureka-server:latest"
                    }
                }
                stage('Docker: API Gateway') {
                    steps {
                        echo '🐳 Building API Gateway image...'
                        bat "docker build -t %DOCKER_REGISTRY%/sms-api-gateway:%IMAGE_TAG% ./backend/api-gateway"
                        bat "docker tag %DOCKER_REGISTRY%/sms-api-gateway:%IMAGE_TAG% %DOCKER_REGISTRY%/sms-api-gateway:latest"
                    }
                }
                stage('Docker: Auth Service') {
                    steps {
                        echo '🐳 Building Auth Service image...'
                        bat "docker build -t %DOCKER_REGISTRY%/sms-auth-service:%IMAGE_TAG% ./backend/auth-service"
                        bat "docker tag %DOCKER_REGISTRY%/sms-auth-service:%IMAGE_TAG% %DOCKER_REGISTRY%/sms-auth-service:latest"
                    }
                }
                stage('Docker: Inventory Service') {
                    steps {
                        echo '🐳 Building Inventory Service image...'
                        bat "docker build -t %DOCKER_REGISTRY%/sms-inventory-service:%IMAGE_TAG% ./backend/inventory-service"
                        bat "docker tag %DOCKER_REGISTRY%/sms-inventory-service:%IMAGE_TAG% %DOCKER_REGISTRY%/sms-inventory-service:latest"
                    }
                }
                stage('Docker: Request Service') {
                    steps {
                        echo '🐳 Building Request Service image...'
                        bat "docker build -t %DOCKER_REGISTRY%/sms-request-service:%IMAGE_TAG% ./backend/request-service"
                        bat "docker tag %DOCKER_REGISTRY%/sms-request-service:%IMAGE_TAG% %DOCKER_REGISTRY%/sms-request-service:latest"
                    }
                }
                stage('Docker: Frontend') {
                    steps {
                        echo '🐳 Building Frontend image...'
                        bat "docker build -t %DOCKER_REGISTRY%/sms-frontend:%IMAGE_TAG% ./frontend"
                        bat "docker tag %DOCKER_REGISTRY%/sms-frontend:%IMAGE_TAG% %DOCKER_REGISTRY%/sms-frontend:latest"
                    }
                }
            }
        }

        // ──────────────────────────────────────────────────
        // Stage 7: Push Docker Images to Registry
        // ──────────────────────────────────────────────────
        stage('Docker Push') {
            steps {
                echo '📤 Pushing Docker images to registry...'
                bat "docker login -u %DOCKER_CREDS_USR% -p %DOCKER_CREDS_PSW% %DOCKER_REGISTRY%"

                bat "docker push %DOCKER_REGISTRY%/sms-config-server:%IMAGE_TAG%"
                bat "docker push %DOCKER_REGISTRY%/sms-config-server:latest"

                bat "docker push %DOCKER_REGISTRY%/sms-eureka-server:%IMAGE_TAG%"
                bat "docker push %DOCKER_REGISTRY%/sms-eureka-server:latest"

                bat "docker push %DOCKER_REGISTRY%/sms-api-gateway:%IMAGE_TAG%"
                bat "docker push %DOCKER_REGISTRY%/sms-api-gateway:latest"

                bat "docker push %DOCKER_REGISTRY%/sms-auth-service:%IMAGE_TAG%"
                bat "docker push %DOCKER_REGISTRY%/sms-auth-service:latest"

                bat "docker push %DOCKER_REGISTRY%/sms-inventory-service:%IMAGE_TAG%"
                bat "docker push %DOCKER_REGISTRY%/sms-inventory-service:latest"

                bat "docker push %DOCKER_REGISTRY%/sms-request-service:%IMAGE_TAG%"
                bat "docker push %DOCKER_REGISTRY%/sms-request-service:latest"

                bat "docker push %DOCKER_REGISTRY%/sms-frontend:%IMAGE_TAG%"
                bat "docker push %DOCKER_REGISTRY%/sms-frontend:latest"
            }
        }

        // ──────────────────────────────────────────────────
        // Stage 8: Deploy with Docker Compose
        // ──────────────────────────────────────────────────
        stage('Deploy') {
            steps {
                echo '🚀 Deploying Stationery Management System...'
                bat 'docker-compose -f ci-cd\docker-compose.yml down --remove-orphans'
                bat 'docker-compose -f ci-cd\docker-compose.yml up -d --build'

                echo '⏳ Waiting for services to become healthy...'
                bat 'timeout /t 60 /nobreak'

                echo '✅ Verifying deployment...'
                bat 'docker-compose -f ci-cd\docker-compose.yml ps'
            }
        }
    }

    // ──────────────────────────────────────────────────────
    // Post-Build Actions
    // ──────────────────────────────────────────────────────
    post {
        always {
            echo '🧹 Cleaning up workspace...'
            bat 'docker logout %DOCKER_REGISTRY% || exit 0'
            cleanWs()
        }
        success {
            echo '✅ ========================================='
            echo '✅  Pipeline SUCCEEDED!'
            echo '✅  Build #${BUILD_NUMBER} deployed.'
            echo '✅ ========================================='
        }
        failure {
            echo '❌ ========================================='
            echo '❌  Pipeline FAILED!'
            echo '❌  Check logs for build #${BUILD_NUMBER}.'
            echo '❌ ========================================='
        }
        unstable {
            echo '⚠️ Pipeline completed with warnings. Review test results.'
        }
    }
}
